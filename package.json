{
  "name": "kimono-one",
  "private": true,
  "type": "module",
  "scripts": {
    "check:agent-context": "tsx scripts/check-agent-context.ts",
    "check:boundaries": "tsx scripts/check-boundaries.ts",
    "check:harness": "pnpm check:agent-context && pnpm check:plans && pnpm check:uiux-harness && pnpm check:boundaries && pnpm check:no-console",
    "check:no-console": "tsx scripts/check-no-console.ts",
    "check:plans": "tsx scripts/check-plan-format.ts",
    "check:uiux-harness": "tsx scripts/check-uiux-harness.ts",
    "bootstrap": "bash scripts/bootstrap.sh",
    "build": "react-router build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:start": "tsx scripts/db-start.ts",
    "db:test": "tsx scripts/db-test.ts",
    "dev": "react-router dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "review:weekly": "tsx scripts/weekly-review.ts",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "isbot": "^5.1.36",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.5"
  }
}
